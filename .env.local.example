# Copy to .env.local and fill in values from your Supabase project's
# Settings → API page.

# Project URL, e.g. https://xyzcompany.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Public anon key (safe to expose to the browser; row-level security is
# enforced server-side). NOT the service_role key — that one stays secret.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
